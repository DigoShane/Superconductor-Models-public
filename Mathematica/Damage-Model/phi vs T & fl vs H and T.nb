Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "[", "T_", "]"}], ":=", 
  RowBox[{"14.6007", "-", 
   RowBox[{"0.215342", " ", "T"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"d", "[", 
    RowBox[{"H_", ",", "T_"}], "]"}], ":=", 
   RowBox[{"1.008", "-", 
    RowBox[{"0.014915", " ", "H"}], "+", 
    RowBox[{"0.000328077", " ", 
     RowBox[{"H", "^", "2"}]}], "-", 
    RowBox[{"0.0014244", " ", "T"}], "+", 
    RowBox[{"0.0003247067", " ", "H", " ", "T"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tmin", "=", "20"}], ";", 
  RowBox[{"Tmax", "=", "46.3"}], ";", 
  RowBox[{"deltaT", "=", "0.001"}], ";"}]}], "Input",
 CellChangeTimes->{{3.971261742956943*^9, 3.9712617431965313`*^9}, {
