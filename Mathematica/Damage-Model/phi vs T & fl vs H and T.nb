Cell[BoxData[{
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "x"}], ")"}], "/", 
           RowBox[{"Log", "[", "x", "]"}]}]}], ")"}], "*", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{
           RowBox[{"c", "[", "T", "]"}], "*", "x"}]}], ")"}]}]}], "}"}], ",", 
     
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "Tmin", ",", "Tmax"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "It", " ", "turns", " ", "out", " ", "that", " ", "we", " ", "cross", 
      " ", "Tmax"}], "=", " ", "46.4"}], ",", " ", 
    RowBox[{
    "we", " ", "dont", " ", "have", " ", "any", " ", "more", " ", "solutions",
      " ", "to", " ", "the", " ", 
     RowBox[{"equation", "."}]}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.971261678220849*^9, 3.971261729979961*^9}, {
