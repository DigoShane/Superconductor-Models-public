Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"xRootsAll", "=", 
    RowBox[{"{", "}"}]}], ";", 
   RowBox[{"(*", 
    RowBox[{"will", " ", "hold", " ", "all", " ", "roots", " ", 
     RowBox[{"{", 
      RowBox[{"T", ",", "x"}], "}"}]}], "*)"}], 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"Loop", " ", "over", " ", "T", " ", "values"}], "==="}], "*)"}], 
   
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"T", "=", "Tmin"}], ",", 
     RowBox[{"T", "\[LessEqual]", "Tmax"}], ",", 
     RowBox[{"T", "+=", "deltaT"}], ",", 
     RowBox[{
      RowBox[{"eqn", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", "x"}], ")"}], "/", 
            RowBox[{"Log", "[", "x", "]"}]}]}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"c", "[", "T", "]"}], "*", "x"}]}], ")"}]}], "\[Equal]", 
        "1"}]}], ";", 
      RowBox[{"sol", "=", 
       RowBox[{"Quiet", "[", 
        RowBox[{"NSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"eqn", ",", 
            RowBox[{"x", ">", "0"}], ",", 
            RowBox[{"x", "<", "1"}]}], "}"}], ",", "x", ",", "Reals"}], "]"}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"xs", "=", 
       RowBox[{"x", "/.", "sol"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"{", 
          RowBox[{"T", ",", "xs"}], "}"}], "]"}], ";"}], 
       RowBox[{"(*", 
        RowBox[{
        "uncomment", " ", "to", " ", "print", " ", "the", " ", "values"}], 
        "*)"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"xs", "=", 
       RowBox[{
        RowBox[{"Select", "[", 
         RowBox[{"xs", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"NumericQ", "[", "#", "]"}], "&&", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Im", "[", "#", "]"}], "]"}], "<", 
             RowBox[{"10", "^", 
              RowBox[{"-", "10"}]}]}]}], "&"}]}], "]"}], "//", "Re"}]}], ";", 
      "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"xs", "=!=", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"xRootsAll", ",", 
          RowBox[{"{", 
           RowBox[{"T", ",", 
            RowBox[{"Max", "[", "xs", "]"}]}], "}"}]}], "]"}]}], "]"}]}]}], 
    "]"}]}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"===", 
    RowBox[{"Convert", " ", "to", " ", "dataset", " ", "or", " ", "plot"}], 
    "==="}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xRootsAll", "//", "TableForm"}], ";"}]}], "Input",
 CellChangeTimes->{{3.971261047311079*^9, 3.9712610473195744`*^9}, {
