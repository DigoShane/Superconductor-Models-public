Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "constants", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"fL0", "=", "7."}], ";"}], "\n", 
   RowBox[{
    RowBox[{"n", "=", "0.33381"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"d", "[", 
      RowBox[{"H_", ",", "T_"}], "]"}], ":=", 
     RowBox[{"1.008", "-", 
      RowBox[{"0.014915", " ", "H"}], "+", 
      RowBox[{"0.000328077", " ", 
       RowBox[{"H", "^", "2"}]}], "-", 
      RowBox[{"0.0014244", " ", "T"}], "+", 
      RowBox[{"0.0003247067", " ", "H", " ", "T"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"pull", " ", "T", " ", "and", " ", "x_s", 
     RowBox[{"(", "T", ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tList", "=", 
     RowBox[{"xRootsAll", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xList", "=", 
     RowBox[{"xRootsAll", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"H", " ", "grid"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Hmin", "=", "0"}], ";", 
    RowBox[{"Hmax", "=", "20"}], ";", 
    RowBox[{"dH", "=", "0.25"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hList", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"Hmin", ",", "Hmax", ",", "dH"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"build", " ", "raw", " ", "3", "D", " ", 
     RowBox[{"points", ":", 
      RowBox[{"{", 
       RowBox[{"H", ",", "T", ",", 
        RowBox[{"fL", "*"}]}], "}"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rawPoints", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"xs", "=", 
              RowBox[{"xList", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ",", 
             RowBox[{"tt", "=", 
              RowBox[{"tList", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"h", ",", "tt", ",", 
             RowBox[{"fL0", "*", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"xs", "/", 
                 RowBox[{"d", "[", 
                  RowBox[{"h", ",", "tt"}], "]"}]}], ")"}], "^", 
               RowBox[{"(", 
                RowBox[{"1", "/", "n"}], ")"}]}]}]}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"Length", "[", "tList", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"h", ",", "hList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"plot", " ", "the", " ", "samples"}], "*)"}], "\n", 
   RowBox[{"ListPlot3D", "[", 
    RowBox[{"rawPoints", ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
       RowBox[{"Red", ",", 
        RowBox[{"PointSize", "[", "Small", "]"}]}], "]"}]}], ",", 
     RowBox[{"BoxRatios", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1", ",", "0.6"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<H\>\"", ",", "\"\<T\>\"", ",", "\"\<fL*\>\""}], "}"}]}], 
     ",", 
     RowBox[{
     "PlotLabel", "\[Rule]", "\"\<fL* vs H and T (sampled points)\>\""}], ",", 
     RowBox[{"Mesh", "\[Rule]", "None"}]}], "]"}]}]}]], "Input",
